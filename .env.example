# Copy to `.env` in the repo root for local development.
# Shell environment variables take precedence over this file.

DATA_ROOT_DIR=./data/reviewer
PORT=8080
# PROJECTS_CONFIG=./projects.yaml

# Minimum free bytes required before a clone / worktree add (default 2GiB).
# REVIEWER_MIN_FREE_BYTES=2147483648

# AI agent provider for weekly batch runs: cursor (default) or claude.
# REVIEWER_AGENT=cursor
# REVIEWER_AGENT=claude

# Optional model for the selected agent CLI (maps to --model). Omit to use agent default.
# REVIEWER_MODEL=claude-sonnet-4

# Comma-separated frontend origins for cross-origin deployment.
# Dev builds (cargo run): defaults to * when unset.
# Release builds: leave unset to disable CORS (use nginx same-domain proxy instead).
# CORS_ALLOW_ORIGINS=*
# CORS_ALLOW_ORIGINS=https://reviewer.example.com,http://localhost:5173
